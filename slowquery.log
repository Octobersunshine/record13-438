SET timestamp=1750238132;
SELECT u.id, u.name, u.email, o.total_amount
FROM users u
LEFT JOIN orders o ON u.id = o.user_id
WHERE u.status = 'active'
  AND o.created_at > '2026-01-01'
GROUP BY u.id
ORDER BY o.total_amount DESC
LIMIT 100;

